# 공개 가능한 값만 (§10.1 / web-stack.md §3). 실제 .env는 커밋 금지.
# 비공개 키(카카오 REST·Anthropic·service_role 등)는 절대 여기 두지 않는다 → Edge Function 시크릿.

# Supabase (P0b부터 필요)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=        # anon 키는 공개 전제 + RLS가 실제 방어선(§10.2)

# 카카오맵 JS SDK (P1c부터 필요) — 도메인 제한된 JavaScript 키만(§5.5)
VITE_KAKAO_JS_KEY=

# 네이버 지도 JS SDK (지도 표시 정본, D5) — NCP Web Dynamic Map, 도메인 등록 필요
VITE_NAVER_MAP_CLIENT_ID=

# 배포 사이트 URL (네이티브 매직링크/OAuth redirect 기준 — 네이티브 WebView의 로컬 origin 누수 방지)
# 예: https://loveplace.app  (미설정 시 window.location.origin 사용)
VITE_PUBLIC_SITE_URL=

# ── 비공개 키는 여기 두지 않는다 → Edge Function 시크릿(supabase secrets set):
#   ANTHROPIC_API_KEY (AI 추천), KAKAO_REST_KEY (검색/길찾기), TMAP_APP_KEY (길찾기 폴백, R5 도로스냅),
#   SUPABASE_SERVICE_ROLE_KEY (프록시 서버), GITHUB_TOKEN (블로그 발행, P5).
